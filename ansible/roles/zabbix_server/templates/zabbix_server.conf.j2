# Zabbix Server configuration file
# Managed by Ansible - DO NOT EDIT MANUALLY

LogFile=/var/log/zabbix/zabbix_server.log
LogFileSize=100
PidFile=/run/zabbix/zabbix_server.pid
SocketDir=/run/zabbix

### Database settings ###
DBHost={{ zabbix_db_host }}
DBPort={{ zabbix_db_port }}
DBName={{ zabbix_db_name }}
DBUser={{ zabbix_db_user }}
DBPassword={{ zabbix_db_password }}

### HA settings ###
HANodeName={{ zabbix_ha_node_name }}
NodeAddress={{ ansible_default_ipv4.address }}:{{ zabbix_server_port }}

### Network settings ###
ListenPort={{ zabbix_server_port }}

### Poller settings ###
StartPollers=10
StartPollersUnreachable=5
StartPingers=5
StartDiscoverers=5
StartHTTPPollers=5

### Cache settings ###
CacheSize={{ zabbix_cache_size }}
HistoryCacheSize={{ zabbix_history_cache_size }}
TrendCacheSize={{ zabbix_trend_cache_size }}
ValueCacheSize={{ zabbix_value_cache_size }}

### Miscellaneous ###
Timeout=10
AlertScriptsPath=/usr/lib/zabbix/alertscripts
ExternalScripts=/usr/lib/zabbix/externalscripts
LogSlowQueries=3000
StatsAllowedIP=127.0.0.1
